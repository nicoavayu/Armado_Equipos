{
  "name": "team-balancer",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/app": "^7.1.2",
    "@capacitor/browser": "^7.0.4",
    "@capacitor/camera": "^7.0.1",
    "@capacitor/core": "^7.4.2",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/geolocation": "^7.1.3",
    "@capacitor/haptics": "^7.0.1",
    "@capacitor/keyboard": "^7.0.2",
    "@capacitor/network": "^7.0.1",
    "@capacitor/preferences": "^7.0.1",
    "@capacitor/push-notifications": "^7.0.1",
    "@capacitor/share": "^7.0.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@sentry/react": "^10.39.0",
    "@supabase/supabase-js": "^2.50.2",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@vercel/functions": "^3.7.5",
    "babel-loader": "^10.0.0",
    "capacitor-native-settings": "^7.0.2",
    "dompurify": "^3.2.7",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.12",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.379.0",
    "maplibre-gl": "^5.24.0",
    "posthog-js": "^1.351.1",
    "react": "^18.3.1",
    "react-country-flag": "^3.1.0",
    "react-countup": "^6.5.3",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-joyride": "^2.9.3",
    "react-lazy-load-image-component": "^1.6.3",
    "react-router-dom": "^6.22.3",
    "react-scripts": "^5.0.1",
    "react-toastify": "^11.0.5",
    "recharts": "^3.1.2",
    "tailwindcss": "^3.4.17",
    "use-places-autocomplete": "^4.0.1",
    "uuid": "^8.3.2",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "prebuild": "node scripts/validate-build-env.mjs",
    "build": "GENERATE_SOURCEMAP=${GENERATE_SOURCEMAP:-false} REACT_APP_AUTH_REDIRECT_URL=com.teambalancer.app://auth/callback react-scripts build && node scripts/write-build-info.mjs",
    "build:mobile:release": "npm run build",
    "build:web:release": "GENERATE_SOURCEMAP=true npm run build",
    "sentry:web:sourcemaps:upload": "node scripts/upload_sentry_sourcemaps.mjs",
    "release:web:sentry": "npm run build:web:release && npm run sentry:web:sourcemaps:upload",
    "test": "react-scripts test",
    "test:ci": "CI=true react-scripts test --watchAll=false --runInBand",
    "test:web-access": "node --test server/__tests__/*.test.mjs",
    "test:db": "node scripts/db-integration/run.mjs",
    "test:db:goalkeeper": "node scripts/db-integration/goalkeeper.mjs",
    "test:db:quierojugar": "node scripts/db-integration/quiero_jugar_v2.mjs",
    "eject": "react-scripts eject",
    "mobile:sync": "npm run build && npx cap sync",
    "android:sync": "npm run build && npx cap sync android",
    "ios:sync": "npm run build && npx cap sync ios",
    "mobile:secrets:sync": "bash scripts/sync_mobile_secrets.sh",
    "android:open": "npx cap open android",
    "ios:open": "npx cap open ios",
    "lint": "eslint src/ --ext .js,.jsx",
    "lint:fix": "eslint src/ --ext .js,.jsx --fix",
    "validate:web-access-env": "node scripts/validate-private-web-env.mjs",
    "migrations:guard": "node scripts/guard_migration_source.mjs",
    "db:list": "npm run migrations:guard && npx supabase migration list --linked",
    "db:push": "npm run migrations:guard && npx supabase db push"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.24.7",
    "@babel/plugin-transform-async-generator-functions": "^7.24.7",
    "@babel/plugin-transform-class-properties": "^7.24.7",
    "@babel/plugin-transform-dynamic-import": "^7.24.7",
    "@babel/plugin-transform-json-strings": "^7.24.7",
    "@babel/plugin-transform-nullish-coalescing-operator": "^7.24.7",
    "@babel/plugin-transform-numeric-separator": "^7.24.7",
    "@babel/plugin-transform-object-rest-spread": "^7.24.7",
    "@babel/plugin-transform-optional-chaining": "^7.24.7",
    "@babel/plugin-transform-private-methods": "^7.24.7",
    "@babel/plugin-transform-private-property-in-object": "^7.24.7",
    "@babel/plugin-transform-unicode-property-regex": "^7.24.7",
    "@capacitor/android": "^7.4.2",
    "@capacitor/cli": "^7.4.2",
    "@capacitor/ios": "^7.4.2",
    "@sentry/cli": "^3.3.3",
    "autoprefixer": "^10.4.23",
    "embedded-postgres": "^18.4.0-beta.17",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-webpack-plugin": "^4.2.0",
    "pg": "^8.22.0",
    "postcss": "^8.5.6",
    "webpack": "^5.92.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  },
  "overrides": {
    "@mapbox/jsonlint-lines-primitives": "2.0.2"
  }
}
