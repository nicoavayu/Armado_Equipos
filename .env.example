# Replace with your actual Supabase project URL and key
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here
# Optional: Force auth callback URL (useful for local dev)
# REACT_APP_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback
# Optional: Web app origin fallback. Browser builds normally use window.location.origin,
# which keeps Vercel preview callbacks on the preview URL.
REACT_APP_PUBLIC_APP_URL=

# Optional: Google Maps JS API keys. Leave blank to disable Places autocomplete/geocoding;
# manual venue text still works. Use the mobile key for native Capacitor builds when it differs.
REACT_APP_GOOGLE_MAPS_API_KEY=
REACT_APP_GOOGLE_MAPS_API_KEY_MOBILE=

# Optional: Sentry monitoring. Set release in CI/Vercel to a unique build id or commit SHA.
REACT_APP_SENTRY_DSN=
REACT_APP_SENTRY_ENVIRONMENT=
REACT_APP_SENTRY_RELEASE=

# Optional: Survey timing/vote thresholds. Defaults are 1 hour, 3, and 3.
REACT_APP_SURVEY_START_DELAY_MS=
REACT_APP_SURVEY_MIN_VOTERS_FOR_AWARDS=
REACT_APP_SURVEY_MIN_VOTERS_IMMEDIATE_FINALIZE=

# Optional: Default nationality for new user profiles (default: argentina)
REACT_APP_DEFAULT_NATIONALITY=argentina

# Optional: Enable XSS sanitization in VotingView (default: false)
# REACT_APP_SANITIZE_VOTING=true

# Survey fanout mode: 'db' makes the DB cron function the canonical creator of post-match surveys.
# Set to 'js' to enable legacy JS fanout (for local/dev testing only: USE_JS_FANOUT=1 may be needed).
REACT_APP_SURVEY_FANOUT_MODE=db

# Feature flag: enables the new "Equipos" tab inside Quiero Jugar.
# Keep false to preserve legacy-only behavior.
REACT_APP_ENABLE_EQUIPOS_TAB=false
